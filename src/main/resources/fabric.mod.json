{
	"schemaVersion": 1,
	"id": "${mod_id}",
	"version": "${mod_version}",
	"name": "${mod_name}",
	"description": "A library for recording Fabric client GameTests.",
	"authors": [
		"brainage04"
	],
	"contact": {
		"homepage": "https://github.com/brainage04/GameTestRecorderLib",
		"sources": "https://github.com/brainage04/GameTestRecorderLib"
	},
	"license": "MIT",
	"environment": "client",
	"entrypoints": {
		"client": [
			"io.github.brainage04.gametestrecorderlib.GameTestRecorderLib"
		]
	},
	"depends": {
		"fabricloader": ">=${loader_version}",
		"minecraft": ">=26.1.2",
		"java": ">=${java_version}",
		"fabric-api": "*"
	},
	"custom": {
		"modmenu": {
			"badges": [
				"library"
			]
		}
	}
}
